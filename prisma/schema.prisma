// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Learner {
  id        String   @id @default(cuid())
  fullName  String
  phone     String?  @unique
  createdAt DateTime @default(now())

  enrollments CourseEnrollment[]
  attempts    QuizAttempt[]
  certificates Certificate[]
}

model CourseEnrollment {
  id           String   @id @default(cuid())
  learnerId    String
  courseCode   String
  status       String   @default("in_progress")
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  learner      Learner  @relation(fields: [learnerId], references: [id])
  dayProgress  DayProgress[]

  @@index([learnerId, courseCode])
}

model DayProgress {
  id           String   @id @default(cuid())
  enrollmentId String
  dayNumber    Int
  status       String   @default("not_started")
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  enrollment   CourseEnrollment @relation(fields: [enrollmentId], references: [id])

  @@unique([enrollmentId, dayNumber])
}

model QuizAttempt {
  id         String   @id @default(cuid())
  learnerId  String
  dayNumber  Int
  questionId String
  answer     String
  correct    Boolean
  createdAt  DateTime @default(now())

  learner    Learner  @relation(fields: [learnerId], references: [id])

  @@index([learnerId, dayNumber])
}

model Certificate {
  id            String   @id @default(cuid())
  learnerId     String
  courseCode    String
  certificateId String   @unique
  issuedAt      DateTime @default(now())

  learner       Learner  @relation(fields: [learnerId], references: [id])

  @@index([learnerId, courseCode])
}
